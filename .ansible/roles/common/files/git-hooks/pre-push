#!/bin/bash
# メインブランチへの直接 push をブロックする
#
# 対象ブランチ: main / master / develop
# 回避策: なし（PR 経由でマージすること）

protected_branches="^(main|master|develop)$"

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  remote_branch="${remote_ref#refs/heads/}"
  if [[ "$remote_branch" =~ $protected_branches ]]; then
    echo ""
    echo "ERROR: $remote_branch ブランチへの直接 push は禁止されています。"
    echo ""
    echo "  feature/fix/chore ブランチから PR を作成してマージしてください。"
    echo ""
    exit 1
  fi
done
