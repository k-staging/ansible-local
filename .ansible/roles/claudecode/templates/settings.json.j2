{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Read",
      "Write(**)",
      "Write(config/locales/**)",
      "Edit(**)",
      "Edit(config/locales/**)",
      "Glob(**)",
      "Grep(**)",
      "Bash"
    ],
    "deny": [
      "Read(tmp/**)",
      "Read(node_modules/**)",
      "Read(storage/**)",
      "Read(public/assets/**)",
      "Read(public/packs/**)",
      "Read(vendor/**)",
      "Read(db/schema.rb)",
      "Read(**/*.sqlite3)",
      "Read(.env*)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(config/master.key)",
      "Read(config/credentials.yml.enc)",
      "Read(config/secrets.yml)",
      "Read(config/database.yml)",
      "Bash(git reset --hard:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh release delete:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue close:*)",
      "Bash(rm -rf /:*)",
      "Bash(dd :*)",
      "Bash(mkfs.:*)",
      "Bash(curl :*| bash:*)",
      "Bash(wget :*| sh:*)",
      "Bash(*> /dev/sd*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
{% if ansible_distribution == 'MacOSX' %}
            "command": "terminal-notifier -title 'Claude Code' -message '処理が完了しました' -sound Ping"
{% else %}
            "command": "notify-send 'Claude Code' '処理が完了しました'"
{% endif %}
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
{% if ansible_distribution == 'MacOSX' %}
            "command": "terminal-notifier -title 'Claude Code' -message ' 入力待ちです' -sound Ping"
{% else %}
            "command": "notify-send 'Claude Code' ' 入力待ちです'"
{% endif %}
          },
          {
            "type": "agent",
            "prompt": "編集されたファイルを確認してください: $ARGUMENTS\n\nファイルパターンに応じて以下をチェック:\n- Dockerfile, docker-compose*.yml, .ansible/**, *.tf, k8s manifest → 構文チェック、セキュリティ、ベストプラクティス\n- .rb, .py, .sql → N+1防止、バグ検出、コーディング規約\n- ActiveRecord/生SQL → インデックス提案、クエリ最適化\n\n該当しないファイルなら何もせず終了。問題があれば指摘し、なければ何も出力しない。",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "voiceEnabled": true,
  "language": "Japanese",
  "defaultMode": "auto",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false"{% if claude_code_experimental_features.agent_teams %},
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"{% endif %}

  }
}
